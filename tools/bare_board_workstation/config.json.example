{
  "firmware_repo": "../..",
  "flash_backend": "nrfjprog",
  "flash_image_path": "../../bare_board_test.hex",
  "flash_script_path": "",
  "nrfjprog_path": "nrfjprog",
  "nrfjprog_family": "NRF54L15_XXAA",
  "jlink_probe_id": "",
  "flash_verify": true,
  "flash_timeout_s": 180.0,
  "flash_after_wait_s": 2.0,
  "serial_port": "",
  "serial_baudrate": 460800,
  "serial_timeout_s": 60.0,
  "serial_open_wait_s": 0.5,
  "test_start_command": "",
  "pass_patterns": [
    "PASS",
    "TEST PASS",
    "RESULT:PASS"
  ],
  "fail_patterns": [
    "FAIL",
    "NG",
    "ERROR",
    "RESULT:FAIL"
  ],
  "end_patterns": [
    "TEST DONE",
    "END",
    "RESULT:"
  ],
  "records_root": "../../bare_board_records",
  "station_id": "BARE",
  "sn_rule": {
    "min_len": 1,
    "max_len": 48,
    "prefix": "",
    "regex": "^[A-Za-z0-9_-]+$"
  }
}
